{
  "name": "atmosiq-v6",
  "version": "6.0.0",
  "private": true,
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "lint": "npm run lint:eslint && npm run lint:imports",
    "lint:eslint": "eslint --max-warnings=0 \"scripts/**/*.{js,mjs,ts}\" \"tests/api/**/*.ts\" \"tests/scripts/**/*.ts\" \"tests/components/**/*.{ts,tsx}\" \"tests/lib/**/*.ts\" \"tests/pages/**/*.{ts,tsx}\" \"lib/**/*.ts\" \"components/**/*.{ts,tsx}\" \"pages/**/*.{ts,tsx}\"",
    "lint:imports": "node scripts/check-api-js-imports.mjs",
    "accept:prod-ready": "node scripts/acceptance-check.mjs --config scripts/acceptance/prod-ready.json",
    "accept:pricing-rollout": "node scripts/acceptance-check.mjs --config scripts/acceptance/pricing-rollout.json",
    "accept:go-live": "node scripts/acceptance-check.mjs --config scripts/acceptance/go-live.json",
    "accept:jasper-eval": "node scripts/eval-jasper.mjs --config scripts/acceptance/jasper-eval.json",
    "test:kg": "vitest run tests/services/knowledgeGraphBuilder.test.ts tests/services/knowledgeGraphService.test.ts tests/lib/graphContext.test.ts tests/components/EvidenceMap.test.tsx tests/components/ReportTraceabilityCard.test.tsx tests/engine/sections-traceability.test.ts",
    "accept:kg": "node scripts/acceptance-check.mjs --config scripts/acceptance/kg.json",
    "render:kg-sample": "RENDER_KG_SAMPLE=1 vitest run scripts/dev/render-kg-traceability-sample.test.ts",
    "render:acceptance": "VITEST_RENDER_FIXTURES=1 vitest run scripts/render-acceptance-fixture.test.ts",
    "render:acceptance:v2.3": "VITEST_RENDER_FIXTURES=1 vitest run scripts/acceptance/render-acceptance-fixture.test.ts",
    "accept:v2.3": "node scripts/acceptance/run-v23.mjs",
    "accept:v2.4": "npm run render:acceptance && node scripts/acceptance-check.mjs --config scripts/acceptance/v2.4.json",
    "accept:v2.5": "npm run render:acceptance && node scripts/acceptance-check.mjs --config scripts/acceptance/v2.5.json",
    "accept:v2.6": "npm run render:acceptance && node scripts/acceptance-check.mjs --config scripts/acceptance/v2.6.json",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:migrate:status": "node scripts/db-migrate.mjs --dry-run"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.4",
    "@sentry/node": "^8.55.0",
    "@sentry/react": "^8.55.0",
    "@supabase/supabase-js": "^2.101.1",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.20",
    "docx": "^9.6.1",
    "docxtemplater": "^3.68.7",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "pdfkit": "^0.18.0",
    "pizzip": "^3.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.1.0",
    "recharts": "^3.8.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "stripe": "^17.5.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.18.0",
    "jsdom": "^29.1.1",
    "pg": "^8.13.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
