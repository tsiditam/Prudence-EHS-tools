{
  "name": "atmosiq-v6",
  "version": "6.0.0",
  "private": true,
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint --max-warnings=0 \"scripts/**/*.{js,mjs,ts}\" \"tests/api/**/*.ts\" \"tests/scripts/**/*.ts\" \"tests/components/**/*.{ts,tsx}\" \"tests/lib/**/*.ts\" \"tests/pages/**/*.{ts,tsx}\" \"lib/**/*.ts\" \"components/**/*.{ts,tsx}\" \"pages/**/*.{ts,tsx}\"",
    "accept:prod-ready": "node scripts/acceptance-check.mjs --config scripts/acceptance/prod-ready.json",
    "accept:pricing-rollout": "node scripts/acceptance-check.mjs --config scripts/acceptance/pricing-rollout.json",
    "accept:go-live": "node scripts/acceptance-check.mjs --config scripts/acceptance/go-live.json"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.4",
    "@sentry/node": "^8.55.0",
    "@sentry/react": "^8.55.0",
    "@supabase/supabase-js": "^2.101.1",
    "cheerio": "^1.2.0",
    "dayjs": "^1.11.20",
    "docx": "^9.6.1",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "pdfkit": "^0.18.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.18.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
