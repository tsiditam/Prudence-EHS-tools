      { "type": "grep_matches", "pattern": "paperclip", "paths": ["src/components/Icons.jsx"] },
      { "type": "file_exists", "path": "tests/lib/useFieldAssistant-photos.test.ts" },
      { "type": "file_exists", "path": "tests/components/FieldAssistant-photos.test.tsx" }
    ]},

    { "id": "SENTRY-PACKAGE", "label": "Sentry package installed", "checks": [
      { "type": "grep_matches", "pattern": "@sentry/", "paths": ["package.json"] }
    ]},
    { "id": "SENTRY-INIT-CALLED", "label": "Sentry.init is called in code", "checks": [
      { "type": "grep_matches", "pattern": "Sentry\\.init", "paths": ["src/", "api/", "lib/"] }
    ]},
    { "id": "SENTRY-PII-SCRUB", "label": "beforeSend hook scrubs PII", "checks": [
      { "type": "grep_matches", "pattern": "beforeSend", "paths": ["src/", "lib/"] }
    ]},
    { "id": "SENTRY-DOCS", "label": "Sentry documentation exists", "checks": [
      { "type": "file_exists", "path": "docs/SENTRY.md" }
    ]},

    { "id": "SMOKE-TEST-SCRIPT", "label": "Production smoke test script exists", "checks": [
      { "type": "file_min_size", "path": "scripts/smoke-test-production.ts", "minBytes": 2000 }
    ]},
    { "id": "SMOKE-TEST-CI", "label": "Smoke test CI workflow exists", "checks": [
      { "type": "file_exists", "path": ".github/workflows/smoke-test.yml" }
    ]},
    { "id": "SMOKE-TEST-USES-STRIPE-TEST-MODE", "label": "Smoke test uses Stripe test mode (never production)", "checks": [
      { "type": "grep_matches", "pattern": "STRIPE_TEST_SECRET_KEY", "paths": ["scripts/smoke-test-production.ts", ".github/workflows/smoke-test.yml"] }
    ]},

    { "id": "ENGINE-MERGE-READINESS-SCRIPT", "label": "Engine merge readiness diagnostic script exists", "checks": [
      { "type": "file_exists", "path": "scripts/engine-merge-readiness.ts" }
    ]},

    { "id": "DOCS-PROD-READY", "label": "Production readiness documentation exists", "checks": [
