      { "type": "grep_matches", "pattern": "iicrc-s520-conditions", "paths": ["src/constants/standards-corpus.js"] },
      { "type": "grep_matches", "pattern": "ashrae-241-2023", "paths": ["src/constants/standards-corpus.js"] },
      { "type": "grep_matches", "pattern": "molhave-tvoc-framework", "paths": ["src/constants/standards-corpus.js"] },
      { "type": "file_exists", "path": "tests/lib/corpus-search.test.ts" }
    ]},

    { "id": "JASPER-L4-VISION-TOOL", "label": "Field Assistant (Jasper) Layer-4 vision tool — multimodal photo analysis wired into the agent loop", "checks": [
      { "type": "grep_matches", "pattern": "analyze_photo", "paths": ["src/constants/field-assistant-tools.js"] },
      { "type": "grep_matches", "pattern": "parsePhotoDataUrl", "paths": ["src/constants/field-assistant-tools.js"] },
      { "type": "grep_matches", "pattern": "ih_review_required", "paths": ["src/constants/field-assistant-tools.js"] },
      { "type": "grep_matches", "pattern": "MAX_PHOTOS_PER_REQUEST", "paths": ["api/field-assistant.ts"] },
      { "type": "grep_matches", "pattern": "ToolDispatchContext", "paths": ["api/field-assistant.ts"] },
      { "type": "grep_matches", "pattern": "Available photos in this conversation", "paths": ["api/field-assistant.ts"] },
      { "type": "grep_matches", "pattern": "vision_usages", "paths": ["api/field-assistant.ts"] }
    ]},

    { "id": "JASPER-L4-VISION-UI", "label": "Field Assistant (Jasper) Layer-4 vision UI — photo attach + send wired through the hook", "checks": [
      { "type": "grep_matches", "pattern": "attachPhoto", "paths": ["src/hooks/useFieldAssistant.js"] },
      { "type": "grep_matches", "pattern": "MAX_PHOTOS_PER_REQUEST", "paths": ["src/hooks/useFieldAssistant.js"] },
      { "type": "grep_matches", "pattern": "photos: photosPayload", "paths": ["src/hooks/useFieldAssistant.js"] },
      { "type": "grep_matches", "pattern": "Attach photo", "paths": ["src/components/FieldAssistant.jsx"] },
