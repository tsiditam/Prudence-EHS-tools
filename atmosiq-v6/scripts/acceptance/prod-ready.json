      { "type": "file_exists", "path": "src/components/ui/JasperFeedbackRow.jsx" },
      { "type": "grep_matches", "pattern": "thumbsUp|thumbsDown", "paths": ["src/components/ui/JasperFeedbackRow.jsx"] }
