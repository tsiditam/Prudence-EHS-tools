      { "type": "grep_matches", "pattern": "userConsentsToTraining", "paths": ["lib/ai-training-consent.ts"] }
    ]},
    { "id": "FEEDBACK-WRITE-PATH", "label": "AI feedback endpoint + UI primitive exist", "checks": [
