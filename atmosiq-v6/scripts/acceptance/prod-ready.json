    { "id": "API-JS-IMPORT-GUARDRAIL", "label": "Lint-time guardrail blocks .js → .ts imports on the API path", "checks": [
      { "type": "file_exists", "path": "scripts/check-api-js-imports.mjs" },
      { "type": "grep_matches", "pattern": "findApiJsTsLandmines", "paths": ["scripts/check-api-js-imports.mjs"] },
      { "type": "file_exists", "path": "tests/scripts/check-api-js-imports.test.ts" },
