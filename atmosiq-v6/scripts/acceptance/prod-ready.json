{
  "feature": "AtmosFlow Production Readiness (Group A)",
  "criteria": [
    { "id": "BUILD-01", "label": "TypeScript typecheck passes", "checks": [{ "type": "npm_script_passes", "script": "typecheck" }] },
    { "id": "BUILD-02", "label": "Test suite passes", "checks": [{ "type": "npm_script_passes", "script": "test" }] },
    { "id": "BUILD-03", "label": "Lint passes with zero warnings", "checks": [{ "type": "npm_script_passes", "script": "lint" }] },

    { "id": "WEBHOOK-IDEMPOTENCY-TABLE", "label": "stripe_webhook_events table migration exists", "checks": [
      { "type": "grep_matches", "pattern": "CREATE TABLE.*stripe_webhook_events", "paths": ["supabase/migrations/", "migrations/", "db/"] }
    ]},
    { "id": "WEBHOOK-IDEMPOTENCY-CHECK", "label": "Webhook handler checks for already-processed event", "checks": [
      { "type": "grep_matches", "pattern": "stripe_webhook_events", "paths": ["api/webhook.ts", "api/webhook.js", "pages/api/webhook.ts"] }
    ]},
    { "id": "WEBHOOK-IDEMPOTENCY-TEST", "label": "Webhook idempotency test exists", "checks": [
      { "type": "file_exists", "path": "tests/api/webhook-idempotency.test.ts" }
    ]},

    { "id": "DELETE-ACCOUNT-PURGES-PII", "label": "Account deletion calls purge across all PII tables", "checks": [
      { "type": "grep_matches", "pattern": "analytics_events", "paths": ["api/delete-account.ts", "api/delete-account.js"] },
      { "type": "grep_matches", "pattern": "credits_ledger", "paths": ["api/delete-account.ts", "api/delete-account.js"] },
      { "type": "grep_matches", "pattern": "purchases", "paths": ["api/delete-account.ts", "api/delete-account.js"] },
      { "type": "grep_matches", "pattern": "deleteUser", "paths": ["api/delete-account.ts", "api/delete-account.js"] }
    ]},
    { "id": "DELETION-AUDIT-TABLE", "label": "deletion_audit table migration exists", "checks": [
      { "type": "grep_matches", "pattern": "CREATE TABLE.*deletion_audit", "paths": ["supabase/migrations/", "migrations/", "db/"] }
    ]},
    { "id": "DELETE-ACCOUNT-TEST", "label": "Account deletion test exists", "checks": [
      { "type": "file_exists", "path": "tests/api/delete-account.test.ts" }
    ]},

    { "id": "PASSWORD-RESET-VERIFY-SCRIPT", "label": "Password reset verification script exists", "checks": [
      { "type": "file_exists", "path": "scripts/verify-password-reset.ts" }
    ]},
    { "id": "PASSWORD-RESET-TEST", "label": "Password reset test exists", "checks": [
      { "type": "file_exists", "path": "tests/api/password-reset.test.ts" }
    ]},

    { "id": "NARRATIVE-RATE-LIMIT-TABLE", "label": "narrative_generations tracking table exists", "checks": [
      { "type": "grep_matches", "pattern": "CREATE TABLE.*narrative_generations", "paths": ["supabase/migrations/", "migrations/", "db/"] }
    ]},
    { "id": "NARRATIVE-RATE-LIMIT-CODE", "label": "Narrative endpoint enforces rate limit", "checks": [
      { "type": "grep_matches", "pattern": "(rate_limit|rateLimit|429)", "paths": ["api/narrative.ts", "api/narrative.js"] }
    ]},
    { "id": "NARRATIVE-RATE-LIMIT-TEST", "label": "Narrative rate limit test exists", "checks": [
      { "type": "file_exists", "path": "tests/api/narrative-rate-limit.test.ts" }
    ]},

    { "id": "PHOTO-BLOB-STORE", "label": "Photo blob store + compaction layer wired into supabaseStorage", "checks": [
      { "type": "file_exists", "path": "src/utils/photoBlobStore.js" },
      { "type": "file_exists", "path": "src/utils/photoCompaction.js" },
      { "type": "grep_matches", "pattern": "compactPhotos", "paths": ["src/utils/supabaseStorage.js"] },
      { "type": "grep_matches", "pattern": "expandPhotos", "paths": ["src/utils/supabaseStorage.js"] },
      { "type": "grep_matches", "pattern": "purgeAssessmentPhotos", "paths": ["src/utils/supabaseStorage.js"] },
      { "type": "file_exists", "path": "tests/lib/photo-blob-store.test.ts" },
      { "type": "file_exists", "path": "tests/lib/photo-compaction.test.ts" },
      { "type": "file_exists", "path": "tests/lib/supabase-storage-photo-compaction.test.ts" }
    ]},

    { "id": "OFFLINE-SYNC-INDICATOR", "label": "Pending-sync indicator exists and queue state is observable", "checks": [
      { "type": "file_exists", "path": "src/components/PendingSyncIndicator.jsx" },
      { "type": "file_exists", "path": "src/hooks/useSyncState.js" },
      { "type": "grep_matches", "pattern": "getSyncState", "paths": ["src/utils/supabaseStorage.js"] },
      { "type": "grep_matches", "pattern": "getQueueDepth", "paths": ["src/utils/supabaseStorage.js"] },
      { "type": "grep_matches", "pattern": "PendingSyncIndicator", "paths": ["src/components/MobileApp.jsx"] },
      { "type": "file_exists", "path": "tests/lib/sync-state.test.ts" },
      { "type": "file_exists", "path": "tests/components/PendingSyncIndicator.test.tsx" }
    ]},

    { "id": "LAB-RESULTS-IMPORT", "label": "Lab Results CSV import + Appendix G renderer", "checks": [
      { "type": "file_exists", "path": "src/utils/labResultsParser.js" },
      { "type": "file_exists", "path": "src/components/LabResultsImport.jsx" },
      { "type": "file_exists", "path": "src/components/docx/sections-lab-results.js" },
      { "type": "grep_matches", "pattern": "buildLabResultsAppendix", "paths": ["src/components/DocxReport.js"] },
      { "type": "grep_matches", "pattern": "LabResultsImport", "paths": ["src/components/SamplingFormsView.jsx"] },
      { "type": "grep_matches", "pattern": "labResults: viewRpt", "paths": ["src/components/MobileApp.jsx"] },
      { "type": "file_exists", "path": "tests/lib/lab-results-parser.test.ts" },
      { "type": "file_exists", "path": "tests/engine/lab-results-appendix.test.ts" }
    ]},

    { "id": "RESURVEY-SCHEDULE", "label": "Re-survey Schedule section is rendered in the consultant DOCX", "checks": [
      { "type": "file_exists", "path": "src/engines/resurveySchedule.js" },
      { "type": "file_exists", "path": "src/components/docx/sections-resurvey.js" },
      { "type": "grep_matches", "pattern": "buildResurveySchedule", "paths": ["src/components/docx/sections-v21client.js"] },
      { "type": "file_exists", "path": "tests/engine/resurvey-schedule.test.ts" },
      { "type": "file_exists", "path": "tests/engine/sections-resurvey.test.ts" }
    ]},

    { "id": "OFFLINE-SW-APP-SHELL", "label": "Service worker precaches the app shell + skips /api/ from caching", "checks": [
      { "type": "file_exists", "path": "scripts/build-precache-manifest.mjs" },
      { "type": "grep_matches", "pattern": "precacheManifestPlugin", "paths": ["vite.config.js"] },
      { "type": "grep_matches", "pattern": "precache-manifest.json", "paths": ["public/sw.js"] },
      { "type": "grep_matches", "pattern": "isApiRequest", "paths": ["public/sw.js"] },
      { "type": "grep_matches", "pattern": "networkFirstWithShellFallback", "paths": ["public/sw.js"] },
      { "type": "file_exists", "path": "tests/scripts/build-precache-manifest.test.ts" }
    ]},

    { "id": "CROSS-ASSESSMENT-MEMORY", "label": "Cross-assessment similarity + Past Patterns panel (Play 2)", "checks": [
      { "type": "file_exists", "path": "src/utils/assessmentSimilarity.js" },
      { "type": "file_exists", "path": "src/hooks/useSimilarAssessments.js" },
      { "type": "file_exists", "path": "src/components/SimilarAssessmentsPanel.jsx" },
      { "type": "grep_matches", "pattern": "SimilarAssessmentsPanel", "paths": ["src/components/MobileApp.jsx"] },
      { "type": "file_exists", "path": "tests/lib/assessment-similarity.test.ts" },
      { "type": "file_exists", "path": "tests/components/SimilarAssessmentsPanel.test.tsx" }
    ]},

    { "id": "PHOTO-ANALYSIS-AI", "label": "Multimodal photo analysis endpoint + IH-Review-Required render path", "checks": [
      { "type": "file_exists", "path": "api/photo-analyze.js" },
      { "type": "file_exists", "path": "src/utils/photoAnalysis.js" },
      { "type": "grep_matches", "pattern": "ih_review_required", "paths": ["api/photo-analyze.js"] },
      { "type": "grep_matches", "pattern": "Never invent a citation", "paths": ["api/photo-analyze.js"] },
      { "type": "grep_matches", "pattern": "analyzePhoto", "paths": ["src/components/PhotoCapture.jsx"] },
      { "type": "grep_matches", "pattern": "AI-PROPOSED", "paths": ["src/components/docx/sections-v21client.js"] },
      { "type": "file_exists", "path": "tests/api/photo-analyze.test.ts" },
      { "type": "file_exists", "path": "tests/lib/photo-analysis.test.ts" }
    ]},

    { "id": "JASPER-WATCH-LIVE-ADVISOR", "label": "Live deterministic advisor surfaces reading-vs-threshold flags during sensor entry (Play 3a)", "checks": [
      { "type": "file_exists", "path": "src/engines/liveAdvisor.js" },
      { "type": "file_exists", "path": "src/components/JasperWatchPanel.jsx" },
      { "type": "grep_matches", "pattern": "JasperWatchPanel", "paths": ["src/components/MobileApp.jsx"] },
      { "type": "grep_matches", "pattern": "evaluateLive", "paths": ["src/components/JasperWatchPanel.jsx"] },
      { "type": "file_exists", "path": "tests/engine/live-advisor.test.ts" },
      { "type": "file_exists", "path": "tests/components/JasperWatchPanel.test.tsx" }
    ]},

    { "id": "STANDARDS-CURRENCY", "label": "Standards Currency layer surfaces ASHRAE 241 / EPA PM2.5 annual / ACGIH TLV references without engine touch", "checks": [
      { "type": "file_exists", "path": "src/engines/contextualStandards.js" },
      { "type": "file_exists", "path": "src/components/docx/sections-methodology-currency.js" },
      { "type": "grep_matches", "pattern": "ASHRAE 241", "paths": ["src/constants/standards.js"] },
      { "type": "grep_matches", "pattern": "EPA PM2.5 Annual NAAQS Revision", "paths": ["src/constants/standards.js"] },
      { "type": "grep_matches", "pattern": "ACGIH TLVs and BEIs", "paths": ["src/constants/standards.js"] },
      { "type": "grep_matches", "pattern": "buildMethodologyCurrency", "paths": ["src/components/DocxReport.js"] },
      { "type": "file_exists", "path": "tests/engine/contextual-standards.test.ts" },
      { "type": "file_exists", "path": "tests/engine/sections-methodology-currency.test.ts" }
    ]},

    { "id": "CALIBRATION-APPENDIX-MAPPER", "label": "Calibration appendix B+E mapper exists and is wired into DocxReport", "checks": [
      { "type": "file_exists", "path": "src/components/docx/calibration-appendix.js" },
      { "type": "grep_matches", "pattern": "buildCalibrationAppendix", "paths": ["src/components/DocxReport.js"] },
      { "type": "grep_matches", "pattern": "augmentWithCalibrationAppendices", "paths": ["src/components/DocxReport.js"] },
      { "type": "file_exists", "path": "tests/engine/calibration-appendix.test.ts" },
      { "type": "file_exists", "path": "tests/engine/calibration-appendix-augment.test.ts" }
    ]},

    { "id": "NARRATIVE-AI-REVIEW-BANNER", "label": "Executive Summary AI narrative is wrapped in a hard 'IH Review Required' banner", "checks": [
      { "type": "grep_matches", "pattern": "IH REVIEW REQUIRED", "paths": ["src/components/docx/sections-core.js"] },
      { "type": "grep_matches", "pattern": "aiReviewRequiredBanner", "paths": ["src/components/docx/sections-core.js"] },
      { "type": "file_exists", "path": "tests/engine/ai-review-required-banner.test.ts" }
    ]},

    { "id": "INSTRUMENT-LOG-IMPORT", "label": "Instrument log CSV/XLSX import aggregates time-series into spot readings via the Logger Studio parser (Play 4a)", "checks": [
      { "type": "file_exists", "path": "src/components/InstrumentLogImport.jsx" },
      { "type": "grep_matches", "pattern": "InstrumentLogImport", "paths": ["src/components/MobileApp.jsx"] },
      { "type": "grep_matches", "pattern": "parseSensorCsv|parseSensorRows", "paths": ["src/components/InstrumentLogImport.jsx"] },
      { "type": "grep_matches", "pattern": "xlsxToRows", "paths": ["src/components/InstrumentLogImport.jsx"] },
      { "type": "file_exists", "path": "tests/components/InstrumentLogImport.test.tsx" }
    ]},

    { "id": "JASPER-L2-TOOL-USE", "label": "Field Assistant (Jasper) Layer-2 tool use — primary-source IAQ knowledge base wired into the agent loop", "checks": [
      { "type": "file_exists", "path": "src/constants/iaq-knowledge-base.js" },
      { "type": "file_exists", "path": "src/constants/field-assistant-tools.js" },
      { "type": "grep_matches", "pattern": "FIELD_ASSISTANT_TOOLS", "paths": ["api/field-assistant.ts"] },
      { "type": "grep_matches", "pattern": "dispatchTool", "paths": ["api/field-assistant.ts"] },
      { "type": "grep_matches", "pattern": "lookup_exposure_limit", "paths": ["src/constants/field-assistant-tools.js"] },
      { "type": "grep_matches", "pattern": "lookup_sampling_method", "paths": ["src/constants/field-assistant-tools.js"] },
      { "type": "grep_matches", "pattern": "lookup_health_effects", "paths": ["src/constants/field-assistant-tools.js"] },
      { "type": "grep_matches", "pattern": "1910.1048", "paths": ["src/constants/iaq-knowledge-base.js"] },
      { "type": "grep_matches", "pattern": "ACGIH TLVs and BEIs 2025", "paths": ["src/constants/iaq-knowledge-base.js"] },
      { "type": "file_exists", "path": "tests/lib/iaq-knowledge-base.test.ts" },
      { "type": "file_exists", "path": "tests/lib/field-assistant-tools.test.ts" }
    ]},

    { "id": "JASPER-L3-CORPUS-SEARCH", "label": "Field Assistant (Jasper) Layer-3 corpus search — TF-IDF retrieval over curated IAQ standards corpus", "checks": [
      { "type": "file_exists", "path": "src/constants/standards-corpus.js" },
      { "type": "file_exists", "path": "src/utils/corpus-search.js" },
      { "type": "grep_matches", "pattern": "search_standards_corpus", "paths": ["src/constants/field-assistant-tools.js"] },
      { "type": "grep_matches", "pattern": "searchCorpus", "paths": ["src/utils/corpus-search.js"] },
