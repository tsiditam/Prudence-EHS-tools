{
  "feature": "HydroScan Phase 0–3 — scaffold, design system, engine, Marlow AI & engine v1.1",
  "criteria": [
    {
      "id": "ENGINE-V11",
      "label": "Engine bumped to v1.1 (Phase 3 improvements)",
      "checks": [
        { "type": "grep_matches", "pattern": "ENGINE_VERSION = '1\\.1", "paths": ["src/version.js"] }
      ]
    },
    {
      "id": "PHASE3-MODULES",
      "label": "Tier precedence, state overlay, LSI, citation tracker, readiness & defensibility present",
      "checks": [
        { "type": "file_exists", "path": "src/engine/tier.ts" },
        { "type": "file_exists", "path": "src/engine/state-overlay.ts" },
        { "type": "file_exists", "path": "src/engine/lsi.ts" },
        { "type": "file_exists", "path": "src/engine/citation-tracker.ts" },
        { "type": "file_exists", "path": "src/engine/readiness.ts" },
        { "type": "file_exists", "path": "src/engine/defensibility.ts" },
        { "type": "grep_matches", "pattern": "escalateTier", "paths": ["src/engine/evaluate.ts"] }
      ]
    },
    {
      "id": "PHASE3-TESTS",
      "label": "Phase 3 versioned engine tests pass",
      "checks": [
        { "type": "file_exists", "path": "tests/engine/phase3.test.ts" },
        { "type": "npm_script_passes", "script": "test" }
      ]
    },
    {
      "id": "MARLOW-ENDPOINT",
      "label": "Marlow streaming SSE endpoint present (Anthropic, no docx deps)",
      "checks": [
        { "type": "file_exists", "path": "api/water-assistant.ts" },
        { "type": "grep_matches", "pattern": "text/event-stream", "paths": ["api/water-assistant.ts"] },
        { "type": "grep_matches", "pattern": "claude-sonnet-4-6", "paths": ["api/water-assistant.ts"] },
        { "type": "grep_excludes", "pattern": "(from|require).{0,20}(docxtemplater|pizzip)", "paths": ["api/water-assistant.ts", "src/constants/water-assistant-tools.js", "src/constants/water-knowledge-base.js"] }
      ]
    },
    {
      "id": "MARLOW-MANIFEST-BOUND",
      "label": "Marlow tools + prompt are manifest-grounded (no invented values)",
      "checks": [
        { "type": "file_exists", "path": "src/constants/water-knowledge-base.js" },
        { "type": "grep_matches", "pattern": "from './standards.js'", "paths": ["src/constants/water-knowledge-base.js", "src/constants/water-assistant-corpus.js"] },
        { "type": "grep_matches", "pattern": "Water Professional Review Required", "paths": ["src/constants/water-assistant-prompt.js"] }
      ]
    },
    {
      "id": "MARLOW-UI",
      "label": "Marlow chat UI + SSE hook wired into the shell",
      "checks": [
        { "type": "file_exists", "path": "src/components/MarlowAssistant.jsx" },
        { "type": "file_exists", "path": "src/hooks/useWaterAssistant.js" },
        { "type": "grep_matches", "pattern": "MarlowAssistant", "paths": ["src/components/MobileApp.jsx"] }
      ]
    },
    {
      "id": "MARLOW-TESTS",
      "label": "Marlow tool-dispatch + bundle-isolation tests pass",
      "checks": [
        { "type": "file_exists", "path": "tests/api/water-assistant-bundle.test.ts" },
        { "type": "npm_script_passes", "script": "test" }
      ]
    },
    {
      "id": "DESIGN-TOKENS",
      "label": "Design-token system ported (tokens + marlow + soft-glass)",
      "checks": [
        { "type": "file_exists", "path": "src/styles/tokens.js" },
        { "type": "file_exists", "path": "src/styles/marlow-tokens.js" },
        { "type": "grep_matches", "pattern": "accent:#0D9488", "paths": ["index.html"] }
      ]
    },
    {
      "id": "ENGINE-EXTRACTED",
      "label": "Compliance + causal engine extracted to typed modules",
      "checks": [
        { "type": "file_exists", "path": "src/engine/index.ts" },
        { "type": "file_exists", "path": "src/engine/evaluate.ts" },
        { "type": "file_exists", "path": "src/engine/causal-chains.ts" },
        { "type": "file_exists", "path": "src/types/engine.ts" }
      ]
    },
    {
      "id": "STANDARDS-MANIFEST",
      "label": "Hardcoded standards manifest is the single source of truth",
      "checks": [
        { "type": "file_exists", "path": "src/constants/standards.js" },
        { "type": "grep_matches", "pattern": "STANDARDS_MANIFEST", "paths": ["src/constants/standards.js"] },
        { "type": "grep_matches", "pattern": "isManifestStandard", "paths": ["src/constants/standards.js"] }
      ]
    },
    {
      "id": "MONOLITH-REWIRED",
      "label": "App shell imports the extracted modules (no inline standards)",
      "checks": [
        { "type": "grep_matches", "pattern": "from '../constants/standards.js'", "paths": ["src/components/MobileApp.jsx"] },
        { "type": "grep_excludes", "pattern": "^const STD = \\{", "paths": ["src/components/MobileApp.jsx"] }
      ]
    },
    {
      "id": "UI-SHELL",
      "label": "Slim App root + MobileApp shell + Icons + bottom nav",
      "checks": [
        { "type": "file_exists", "path": "src/components/MobileApp.jsx" },
        { "type": "file_exists", "path": "src/components/Icons.jsx" },
        { "type": "grep_matches", "pattern": "export default function App", "paths": ["src/App.jsx"] },
        { "type": "grep_matches", "pattern": "Bottom navigation", "paths": ["src/components/MobileApp.jsx"] },
        { "type": "grep_excludes", "pattern": "Outfit:wght", "paths": ["src/components/MobileApp.jsx"] }
      ]
    },
    {
      "id": "ENGINE-TESTS",
      "label": "Engine golden fixtures + manifest-integrity tests pass",
      "checks": [
        { "type": "file_exists", "path": "tests/engine/manifest-integrity.test.ts" },
        { "type": "npm_script_passes", "script": "test" }
      ]
    },
    {
      "id": "TS-CONFIG",
      "label": "TypeScript config present (@/* alias, bundler resolution)",
      "checks": [
        { "type": "file_exists", "path": "tsconfig.json" },
        { "type": "file_exists", "path": "tsconfig.check.json" },
        { "type": "grep_matches", "pattern": "\"@/\\*\"", "paths": ["tsconfig.json"] }
      ]
    },
    {
      "id": "API-IMPORT-GUARDRAIL",
      "label": "API-graph .js→.ts import guardrail script present and clean",
      "checks": [
        { "type": "file_exists", "path": "scripts/check-api-js-imports.mjs" },
        { "type": "npm_script_passes", "script": "lint:imports" }
      ]
    },
    {
      "id": "ACCEPTANCE-RUNNER",
      "label": "Acceptance runner present",
      "checks": [
        { "type": "file_exists", "path": "scripts/acceptance-check.mjs" }
      ]
    },
    {
      "id": "ESLINT-CONFIG",
      "label": "ESLint flat config present",
      "checks": [
        { "type": "file_exists", "path": "eslint.config.mjs" }
      ]
    },
    {
      "id": "VITE-PORT",
      "label": "Vite dev server pinned to port 3003",
      "checks": [
        { "type": "grep_matches", "pattern": "port:\\s*3003", "paths": ["vite.config.js"] }
      ]
    },
    {
      "id": "VERSION-SOT",
      "label": "Version source-of-truth present (app/engine/manifest)",
      "checks": [
        { "type": "file_exists", "path": "src/version.js" },
        { "type": "grep_matches", "pattern": "ENGINE_VERSION", "paths": ["src/version.js"] },
        { "type": "grep_matches", "pattern": "STANDARDS_MANIFEST_VERSION", "paths": ["src/version.js"] }
      ]
    },
    {
      "id": "ENV-SCAFFOLD",
      "label": "Environment variables documented (all required keys)",
      "checks": [
        { "type": "file_exists", "path": "docs/ENVIRONMENT.md" },
        { "type": "grep_matches", "pattern": "ANTHROPIC_API_KEY", "paths": ["docs/ENVIRONMENT.md"] },
        { "type": "grep_matches", "pattern": "SUPABASE_SERVICE_ROLE_KEY", "paths": ["docs/ENVIRONMENT.md"] }
      ]
    },
    {
      "id": "BUILD-GREEN",
      "label": "Production build succeeds",
      "checks": [
        { "type": "npm_script_passes", "script": "build" }
      ]
    }
  ]
}
